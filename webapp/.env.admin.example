# 관리자 자동화 스크립트(scripts/)용 — 절대 커밋되지 않음 (.gitignore의 .env* 규칙)
# 실제 값을 채운 파일명은 .env.admin.local 로 저장하세요.
#
# service_role(secret) 키: Supabase 대시보드 → 프로젝트 → 왼쪽 톱니바퀴 Project Settings
#   → API Keys → "service_role" / "secret" 항목 Reveal 후 복사
SUPABASE_SERVICE_ROLE_KEY=

# DB 연결 문자열: Supabase 대시보드 → Project Settings → Database → Connection string
#   → "URI" 탭, Direct connection 선택 → [YOUR-PASSWORD]를 실제 DB 비밀번호로 교체
SUPABASE_DB_URL=

# 이미 알고 있는 값 (webapp/.env.local과 동일, 참고용으로 여기도 채워두면 스크립트가 바로 사용)
NEXT_PUBLIC_SUPABASE_URL=https://unazmttaqqukrlupmnhr.supabase.co
