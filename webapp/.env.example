# Supabase 프로젝트 → Settings → API 에서 확인
# anon public key는 클라이언트에 노출돼도 안전한 키입니다 (RLS로 보호됨).
# service_role 키는 절대 여기 넣지 마세요.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# resend.com → API Keys 에서 발급. 서버(API 라우트)에서만 쓰이며 클라이언트에
# 노출되지 않으니 NEXT_PUBLIC_ 접두사 붙이지 마세요. 없으면 예약 상태변경
# 이메일 발송만 조용히 건너뜁니다(기능 자체는 그대로 동작).
RESEND_API_KEY=
